{
  "version": 2,
  "buildCommand": "node ./scripts/vercel-build.js",
  "outputDirectory": "dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/auth-login",
      "dest": "/api/auth?action=login"
    },
    {
      "src": "/api/auth-register",
      "dest": "/api/auth?action=register"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
